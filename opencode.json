{
    "$schema": "https://opencode.ai/config.json",
    "theme": "K",
    "autoupdate": true,
    "plugin": [
        "opencode-anthropic-auth@0.0.11"
    ],
    "mcp": {
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "enabled": false
        }
    },
    "agent": {
        "build": {
            "disable": true
        },
        "plan": {
            "disable": true
        }
    },
    "keybinds": {
        "messages_page_up": "<leader>u",
        "messages_page_down": "<leader>e",
        "messages_half_page_up": "ctrl+u",
        "messages_half_page_down": "ctrl+e",
        "messages_first": "<leader>g",
        "messages_last": "<leader>shift+g",
        "messages_last_user": "<leader>;"
    }
}
